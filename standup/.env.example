# ============================================================
# GitHub
# ============================================================
GITHUB_ORG=FARO-DataLab
GITHUB_USERNAME=leonelmarinaro

# Path al binario de gh CLI (necesario para LaunchAgent)
GH_BIN=/opt/homebrew/bin/gh

# ============================================================
# Slack — destino principal del daily standup
# ============================================================
# 1. Ir a api.slack.com/apps → Create New App → From scratch
# 2. Features → Incoming Webhooks → Activate Incoming Webhooks
# 3. Add New Webhook to Workspace → elegir canal → Allow
# 4. Copiar la Webhook URL
SLACK_WEBHOOK_URL=

# ============================================================
# Telegram — reservado para triggers y futuros usos
# ============================================================
# 1. Crear bot en @BotFather con /newbot
# 2. Copiar el token que te da BotFather
TELEGRAM_BOT_TOKEN=

# Para obtener tu chat ID:
# - Enviar cualquier mensaje al bot
# - Visitar: https://api.telegram.org/bot<TOKEN>/getUpdates
# - Buscar: result[0].message.from.id
TELEGRAM_CHAT_ID=

# ============================================================
# Obsidian
# ============================================================
# Ruta absoluta a la vault donde se guardan los reportes
# Los archivos se crean en <VAULT>/00-Inbox/daily_report_YYYY-MM-DD.md
OBSIDIAN_VAULT_PATH=/Users/lmarinaro/Documents/Obsidian/Growketing

# ============================================================
# General
# ============================================================
TIMEZONE=America/Argentina/Buenos_Aires
