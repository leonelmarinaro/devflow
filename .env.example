# ============================================================
# CONFIGURACIÓN GENERAL
# ============================================================
TIMEZONE=America/Argentina/Buenos_Aires

# ============================================================
# n8n
# ============================================================
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme

# URL pública donde n8n recibirá webhooks
# Local: http://localhost:5678/
# VPS: https://n8n.tudominio.com/
WEBHOOK_URL=http://localhost:5678/

N8N_LOG_LEVEL=info
N8N_ENCRYPTION_KEY=cambia_esto_por_un_valor_aleatorio_seguro

# ============================================================
# PostgreSQL
# ============================================================
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=changeme_postgres

# ============================================================
# Telegram
# ============================================================
# Obtener en @BotFather → /newbot
TELEGRAM_BOT_TOKEN=

# Tu chat ID personal (para recibir notificaciones)
# Obtener enviando un mensaje al bot y consultando:
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=

# ============================================================
# FastAPI
# ============================================================
FASTAPI_SECRET_KEY=cambia_esto_por_un_valor_aleatorio_seguro
FASTAPI_ALLOWED_ORIGINS=http://localhost:5678

# ============================================================
# Google APIs (opcional)
# ============================================================
# Crear proyecto en console.cloud.google.com
# Habilitar: Google Drive API, Google Docs API, Google Sheets API
# Crear credenciales OAuth2 y descargar JSON
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
